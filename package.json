{
  "name": "niyatna-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "bun scripts/write-headers.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "verify:prerender": "bun -e \"import fs from 'node:fs'; const html = fs.existsSync('dist/index.html') ? fs.readFileSync('dist/index.html', 'utf8') : ''; const checks = ['Niyatna', 'Human intent', 'OpenIntent', 'Proof of Intent']; const missing = checks.filter((s) => !html.includes(s)); if (missing.length) { console.error('Prerender check failed:', missing.join(', ')); process.exit(1); } console.log('Prerender check passed.');\"",
    "deploy": "wrangler pages deploy dist"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@unhead/react": "^3.1.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^3.6.0",
    "vite-plugin-react-ssg": "^0.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250514.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "js-yaml": "^4.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.25.0"
  }
}
