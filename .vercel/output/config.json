      "contentType": "application/json"
    },
    "500.rsc.json": {
      "path": "500.rsc",
      "contentType": "application/json"
    },
    "500.segments/_tree.segment.rsc.json": {
      "path": "500.segments/_tree.segment.rsc",
      "contentType": "application/json"
    },
    "favicon.ico": {
      "contentType": "image/x-icon"
